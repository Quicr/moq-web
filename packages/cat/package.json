{
  "name": "@moq-web/cat",
  "version": "0.1.0",
  "description": "Common Access Token (CAT/C4M) for MoQ Transport — CBOR/COSE/CWT token library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
