{
  "name": "web-moq",
  "version": "0.1.0",
  "private": true,
  "description": "Media over QUIC Transport (MOQT) TypeScript library",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "MOQT_VERSION=draft-16 bun run --filter '*' build",
    "build:draft-14": "MOQT_VERSION=draft-14 bun run --filter '*' build",
    "test": "MOQT_VERSION=draft-16 bun run --filter '*' test",
    "test:draft-14": "MOQT_VERSION=draft-14 bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "dev": "MOQT_VERSION=draft-16 bun run --filter @web-moq/client dev",
    "dev:draft-14": "MOQT_VERSION=draft-14 bun run --filter @web-moq/client dev",
    "clean": "bun run --filter '*' clean"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  }
}
