{
  "name": "web-moq",
  "version": "0.1.0",
  "private": true,
  "description": "Media over QUIC Transport (MOQT) TypeScript libraryx",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:draft-16": "MOQT_VERSION=draft-16 pnpm -r run build",
    "test": "pnpm -r run test",
    "test:draft-16": "MOQT_VERSION=draft-16 pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev": "pnpm --filter @web-moq/client run dev",
    "dev:draft-16": "MOQT_VERSION=draft-16 pnpm --filter @web-moq/client run dev",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
