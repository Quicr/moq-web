{
  "name": "web-moq",
  "version": "0.1.0",
  "private": true,
  "description": "Media over QUIC Transport (MOQT) TypeScript libraryx",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:draft-16": "MOQT_VERSION=draft-16 pnpm -r run build",
    "test": "pnpm -r run test",
    "test:draft-16": "MOQT_VERSION=draft-16 pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev": "pnpm --filter @web-moq/client run dev",
    "dev:draft-16": "MOQT_VERSION=draft-16 pnpm --filter @web-moq/client run dev",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch": ">=10.2.1"
    }
  }
}
